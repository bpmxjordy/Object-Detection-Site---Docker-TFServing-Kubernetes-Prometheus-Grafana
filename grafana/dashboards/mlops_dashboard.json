{
  "annotations": { "list": [] },
  "description": "MLOps monitoring dashboard for the Object Detection pipeline. Tracks inference latency, request throughput, detection class distributions, and TensorFlow Serving health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Inference Request Rate",
      "description": "Rate of inference requests per second, split by success/failure status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(inference_requests_total{status=\"success\"}[1m])",
          "legendFormat": "Successful",
          "refId": "A"
        },
        {
          "expr": "rate(inference_requests_total{status=\"failure\"}[1m])",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [ { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } } ]
          },
          {
            "matcher": { "id": "byName", "options": "Successful" },
            "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ]
          }
        ]
      }
    },
    {
      "title": "Inference Latency (ms)",
      "description": "Histogram of inference latency showing p50, p90, and p99 percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(inference_latency_ms_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, rate(inference_latency_ms_bucket[5m]))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(inference_latency_ms_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Total Requests",
      "description": "Cumulative total of all inference requests processed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "sum(inference_requests_total)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }
      }
    },
    {
      "title": "Successful Requests",
      "description": "Total successful inference requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "inference_requests_total{status=\"success\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } }
      }
    },
    {
      "title": "Failed Requests",
      "description": "Total failed inference requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "inference_requests_total{status=\"failure\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null } ] } }
      }
    },
    {
      "title": "Last Inference Latency",
      "description": "Latency of the most recent inference request in milliseconds",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "last_inference_latency_ms",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          },
          "min": 0,
          "max": 5000
        }
      }
    },
    {
      "title": "Last Detection Count",
      "description": "Number of objects detected in the most recent inference",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "last_detection_count",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "purple", "value": null } ] } }
      }
    },
    {
      "title": "Average Inference Latency",
      "description": "Average inference latency over the last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(inference_latency_ms_sum[5m]) / rate(inference_latency_ms_count[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }
      }
    },
    {
      "title": "Objects Detected by Class",
      "description": "Breakdown of total detections by COCO object class",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "objects_detected_total",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      }
    },
    {
      "title": "Detections Over Time by Class",
      "description": "Rate of detections per class over time, showing which objects are most frequently detected",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(objects_detected_total[5m])",
          "legendFormat": "{{class_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "TF Serving - Model Prediction Count",
      "description": "Number of predictions made by TensorFlow Serving (from TF Serving's built-in metrics)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(:tensorflow:serving:request_count[1m])",
          "legendFormat": "Prediction Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "TF Serving - Prediction Latency",
      "description": "Latency of TensorFlow Serving predictions (from TF Serving's built-in metrics)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(:tensorflow:serving:request_latency_sum[5m]) / rate(:tensorflow:serving:request_latency_count[5m])",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["mlops", "object-detection", "tensorflow"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Object Detection MLOps Dashboard",
  "uid": "object-detection-mlops",
  "version": 1
}
